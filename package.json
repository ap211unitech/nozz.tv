  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "test:unit": "ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check && eslint \"*/**/*.ts\"",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w && eslint \"*/**/*.ts\" --fix",
    "keys:sync": "anchor keys sync",
    "deploy:localnet": "anchor deploy --provider.cluster localnet",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "deploy:mainnet": "anchor deploy --provider.cluster mainnet"
  },
